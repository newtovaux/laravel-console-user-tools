{
    "name": "newtovaux/laravel-console-user-tools",
    "description": "Artisan commands for generating passwords and changing Laravel user passwords.",
    "keywords": ["laravel","console", "artisan", "password", "user", "tools"],
    "homepage": "https://github.com/newtovaux/laravel-console-user-tools",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/console": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Newtovaux\\LaravelConsoleUserTools\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Newtovaux\\LaravelConsoleUserTools\\LaravelConsoleUserToolsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
